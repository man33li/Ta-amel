# MindForge — local-first configuration.
# All variables are optional. Defaults are sensible for `npm run dev`.

# Where the SQLite file lives. If unset, defaults to <repo>/data/mindforge.db.
# MINDFORGE_DATA_DIR=/home/you/.mindforge

# Or, set the full path explicitly. Wins over MINDFORGE_DATA_DIR.
# MINDFORGE_DB_PATH=/home/you/.mindforge/mindforge.db

# Set to 1 to skip semantic embeddings entirely. Palace search will still
# work via keyword + recency lanes. Useful for low-RAM machines or when
# you don't want the ~25MB ONNX model on disk.
# MINDFORGE_EMBEDDINGS_DISABLED=1
